o-explicit-any","Unexpected any. Specify a different type.","TSAnyKeyword","unexpectedAny",{"range":"2161","text":"2162"},["2163","2164"],["2165"],{"range":"2166","text":"2162"},["2167","2168"],["2169"],"React Hook useEffect was passed a dependency list that is not an array literal. This means we can't statically verify whether you've passed the correct dependencies.",["2170"],"React Hook useEffect has missing dependencies: 'execute' and 'immediate'. Either include them or remove the dependency array.",["2171"],["2172"],"React Hook React.useEffect has a missing dependency: 'options'. Either include it or remove the dependency array.",["2173"],["2174"],"React Hook React.useEffect has an unnecessary dependency: 'queryClient'. Either exclude it or remove the dependency array. Outer scope values like 'queryClient' aren't valid dependencies because mutating them doesn't re-render the component.",["2175"],["2176"],"import/no-named-as-default-member","Caution: `i18n` also has a named export `use`. Check if you meant to write `import {use} from 'i18next'` instead.","MemberExpression",["2177"],{"range":"2178","text":"2162"},["2179","2180"],["2181"],{"range":"2182","text":"2162"},["2183","2184"],["2185"],{"range":"2186","text":"2162"},["2187","2188"],["2189"],{"range":"2190","text":"2162"},["2191","2192"],["2193"],{"desc":"2194","fix":"2195"},{"kind":"2196","justification":"2197"},{"kind":"2196","justification":"2197"},{"kind":"2196","justification":"2197"},{"kind":"2196","justification":"2197"},{"desc":"2198","fix":"2199"},{"kind":"2196","justification":"2197"},{"desc":"2200","fix":"2201"},{"kind":"2196","justification":"2197"},{"desc":"2202","fix":"2203"},{"kind":"2196","justification":"2197"},[1106,1109],"unknown",{"messageId":"2204","fix":"2205","desc":"2206"},{"messageId":"2207","fix":"2208","desc":"2209"},{"kind":"2196","justification":"2197"},[1515,1518],{"messageId":"2204","fix":"2210","desc":"2206"},{"messageId":"2207","fix":"2211","desc":"2209"},{"kind":"2196","just