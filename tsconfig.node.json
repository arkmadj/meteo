{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": ".tsbuildinfo-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "scripts/**/*.ts", "scripts/**/*.js"]
}
